#!/bin/bash
set -euo pipefail

APP_ROOT="${APP_ROOT:-/opt/app-root/src}"
PORT="${PORT:-8080}"
DOC_ROOT="${DOC_ROOT:-${APP_ROOT}}"

cd "${APP_ROOT}"

if [[ ! -f "${DOC_ROOT}/index.html" && -f "${APP_ROOT}/src/index.html" ]]; then
  DOC_ROOT="${APP_ROOT}/src"
fi

export APP_ROOT
export PORT
export DOC_ROOT

echo "Environment:"
echo "        DEV_MODE=${DEV_MODE:-false}"
echo "        NODE_ENV=${NODE_ENV:-production}"
echo "        DEBUG_PORT=${DEBUG_PORT:-5858}"

if [[ -f package.json ]]; then
  echo "Launching via npm..."
  exec npm run "${NPM_RUN:-start}"
fi

if command -v httpd >/dev/null 2>&1; then
  echo "No package.json found. Launching httpd..."
  exec httpd -D FOREGROUND
fi

if command -v php >/dev/null 2>&1; then
  echo "No package.json found. Launching php built-in server on port ${PORT} from ${DOC_ROOT}..."
  exec php -S "0.0.0.0:${PORT}" -t "${DOC_ROOT}"
fi

if command -v node >/dev/null 2>&1; then
  echo "No package.json found. Launching Node static file server on port ${PORT} from ${DOC_ROOT}..."
  exec node -e '
const http = require("http");
const fs = require("fs");
const path = require("path");

const root = process.env.DOC_ROOT || process.env.APP_ROOT || "/opt/app-root/src";
const port = Number(process.env.PORT || 8080);
const resolvedRoot = path.resolve(root);
const types = {
  ".html": "text/html",
  ".htm": "text/html",
  ".css": "text/css",
  ".js": "application/javascript",
  ".json": "application/json",
  ".txt": "text/plain",
  ".png": "image/png",
  ".jpg": "image/jpeg",
  ".jpeg": "image/jpeg",
  ".gif": "image/gif",
  ".svg": "image/svg+xml"
};

http.createServer((req, res) => {
  const cleanPath = decodeURIComponent(req.url.split("?")[0]);
  const relPath = cleanPath === "/" ? "index.html" : cleanPath.replace(/^\/+/, "");
  const filePath = path.resolve(resolvedRoot, relPath);

  if (filePath !== resolvedRoot && !filePath.startsWith(resolvedRoot + path.sep)) {
    res.writeHead(403);
    res.end("Forbidden");
    return;
  }

  fs.stat(filePath, (err, stat) => {
    if (err || !stat.isFile()) {
      res.writeHead(404);
      res.end("Not found");
      return;
    }

    const ext = path.extname(filePath).toLowerCase();
    res.writeHead(200, { "Content-Type": types[ext] || "application/octet-stream" });
    fs.createReadStream(filePath).pipe(res);
  });
}).listen(port, "0.0.0.0", () => {
  console.log(`Serving ${root} on 0.0.0.0:${port}`);
});
'
fi

echo "ERROR: No supported runtime found (npm/httpd/php/node)."
exit 1
